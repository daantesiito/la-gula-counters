# Vercel KV — auto-injected when you link a KV store in the Vercel dashboard.
# For local dev: run `vercel env pull .env.local` to populate these.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Kick webhook signature verification (future use — see /api/subs/webhook/route.ts)
KICK_WEBHOOK_SECRET=
